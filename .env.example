# =============================================================================
# Invoice Intelligence Platform — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development                       # development | staging | production
APP_NAME="Invoice Intelligence Platform"
APP_VERSION=0.1.0
DEBUG=true

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://invoice_user:invoice_pass@localhost:5432/invoice_db

# Used by Alembic CLI only (sync driver)
DATABASE_URL_SYNC=postgresql+psycopg2://invoice_user:invoice_pass@localhost:5432/invoice_db

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false         # Set to true to log all SQL statements

# ---------------------------------------------------------------------------
# File Storage (Phase 1: local disk; Phase 2+: S3 / Supabase)
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local                     # local | s3 | supabase
UPLOAD_PATH=./uploads                     # Local storage base directory
MAX_UPLOAD_SIZE_MB=25                     # Maximum file size in megabytes
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg

# S3 settings (used when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Supabase settings (used when STORAGE_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET_NAME=

# ---------------------------------------------------------------------------
# OCR
# ---------------------------------------------------------------------------
OCR_PROVIDER=google_vision               # google_vision (paddleocr/easyocr planned, not implemented)
GOOGLE_VISION_API_KEY=                   # Required when OCR_PROVIDER=google_vision

# ---------------------------------------------------------------------------
# AI Structuring
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai                      # openai (claude/gemini/azure planned, not implemented)
OPENAI_API_KEY=                          # Required when LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_TOKENS_PER_DOCUMENT=6000

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
VALIDATION_ROUNDING_TOLERANCE=0.02       # Max acceptable rounding drift on math checks
REVIEW_CONFIDENCE_THRESHOLD=0.85         # Composite confidence below this routes to review

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                          # json | console
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/app.log
LOG_FILE_ROTATION=10 MB
LOG_FILE_RETENTION=30 days

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-32-char-string-in-production
API_KEY_HEADER=X-API-Key
ACCESS_TOKEN_EXPIRE_MINUTES=60
